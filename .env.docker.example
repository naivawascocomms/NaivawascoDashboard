POSTGRES_DB=naivawasco_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret

# Add the production server IP/hostname so staff can access it from the LAN.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.2.100
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://192.168.2.100:8080

FRONTEND_PORT=8080
BACKEND_PORT=8000

# Required only if this server should pull Android app readings/incidents from Supabase.
MOBILE_SUPABASE_DATABASE_URL=
MOBILE_SUPABASE_URL=
MOBILE_SUPABASE_SERVICE_ROLE_KEY=
MOBILE_SUPABASE_DEFAULT_PASSWORD=
MOBILE_SYNC_INTERVAL=10
