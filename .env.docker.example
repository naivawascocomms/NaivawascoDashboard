POSTGRES_DB=naivawasco_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret

# Add the production server IP/hostname so staff can access it from the LAN.
# Add your Cloudflare public hostname when you expose the app externally.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,app.naivawasco.online
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://app.naivawasco.online

# Optional, but recommended for Django form/admin traffic behind Cloudflare HTTPS.
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.naivawasco.online

FRONTEND_PORT=8080
BACKEND_PORT=8000

# Required only when enabling the Cloudflare Tunnel profile.
CLOUDFLARE_TUNNEL_TOKEN=

# Required only if this server should pull Android app readings/incidents from Supabase.
MOBILE_SUPABASE_DATABASE_URL=
MOBILE_SUPABASE_URL=
MOBILE_SUPABASE_SERVICE_ROLE_KEY=
MOBILE_SUPABASE_DEFAULT_PASSWORD=
MOBILE_SYNC_INTERVAL=10
