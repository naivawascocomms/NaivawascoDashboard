POSTGRES_DB=naivawasco_staging
POSTGRES_USER=naivawasco_staging
POSTGRES_PASSWORD=replace-with-long-random-password

DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_ALLOWED_HOSTS=staging.your-domain.com,localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=https://staging.your-domain.com
DATABASE_CONN_MAX_AGE=60
GUNICORN_WORKERS=2

FRONTEND_PORT=8081

BACKEND_IMAGE=ghcr.io/YOUR_ORG/naivawasco-backend:staging
FRONTEND_IMAGE=ghcr.io/YOUR_ORG/naivawasco-frontend:staging

CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-staging-tunnel-token

