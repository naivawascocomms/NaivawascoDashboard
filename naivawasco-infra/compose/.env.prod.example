POSTGRES_DB=naivawasco_prod
POSTGRES_USER=naivawasco
POSTGRES_PASSWORD=replace-with-long-random-password

DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_ALLOWED_HOSTS=app.your-domain.com,localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=https://app.your-domain.com
DATABASE_CONN_MAX_AGE=60
GUNICORN_WORKERS=3

FRONTEND_PORT=8080

BACKEND_IMAGE=ghcr.io/YOUR_ORG/naivawasco-backend:prod
FRONTEND_IMAGE=ghcr.io/YOUR_ORG/naivawasco-frontend:prod

CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-prod-tunnel-token

